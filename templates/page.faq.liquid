<style>
.faq-page {
  padding: 10rem 4rem 8rem;
  max-width: 860px;
  margin: 0 auto;
}
.faq-header {
  margin-bottom: 5rem;
}
.faq-header h1 {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(3rem, 5vw, 5rem);
  font-weight: 300;
  line-height: 1;
  margin-bottom: 1rem;
}
.faq-header h1 em { font-style: italic; color: var(--warm); }
.faq-header p {
  font-size: 0.82rem;
  color: var(--muted);
  line-height: 1.9;
  max-width: 480px;
}
.faq-list {
  display: flex;
  flex-direction: column;
}
.faq-item {
  border-top: 1px solid rgba(255,255,255,0.06);
}
.faq-item:last-child {
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.faq-question {
  width: 100%;
  background: none;
  border: none;
  color: var(--paper);
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.25rem;
  font-weight: 300;
  text-align: left;
  padding: 2rem 0;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 2rem;
  transition: color 0.3s;
}
.faq-question:hover { color: var(--warm); }
.faq-icon {
  font-size: 1.5rem;
  color: var(--warm);
  transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  flex-shrink: 0;
  line-height: 1;
}
.faq-item.open .faq-icon { transform: rotate(45deg); }
.faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.faq-answer-inner {
  font-size: 0.85rem;
  line-height: 2;
  color: var(--muted);
  padding-bottom: 2rem;
  max-width: 680px;
}
</style>

<div class="faq-page">
  <div class="faq-header reveal">
    <span class="section-label">{{ section.settings.label }}</span>
    <h1>{{ section.settings.heading }} <em>{{ section.settings.heading_em }}</em></h1>
    <p>{{ section.settings.subheading }}</p>
  </div>

  <div class="faq-list">
    {% for block in section.blocks %}
      <div class="faq-item reveal" {{ block.shopify_attributes }}>
        <button class="faq-question">
          {{ block.settings.question }}
          <span class="faq-icon">+</span>
        </button>
        <div class="faq-answer">
          <div class="faq-answer-inner">{{ block.settings.answer }}</div>
        </div>
      </div>
    {% endfor %}
  </div>
</div>

<script>
  document.querySelectorAll('.faq-question').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const answer = item.querySelector('.faq-answer');
      const isOpen = item.classList.contains('open');

      document.querySelectorAll('.faq-item').forEach(i => {
        i.classList.remove('open');
        i.querySelector('.faq-answer').style.maxHeight = '0';
      });

      if (!isOpen) {
        item.classList.add('open');
        answer.style.maxHeight = answer.scrollHeight + 'px';
      }
    });
  });
</script>

{% schema %}
{
  "name": "FAQ Page",
  "settings": [
    { "type": "text", "id": "label", "label": "Section Label", "default": "Support" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently Asked" },
    { "type": "text", "id": "heading_em", "label": "Heading Italic Word (gold)", "default": "Questions" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Everything you need to know about Angles Apparel. Can't find what you're looking for? Contact us." }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "What is your return policy?" },
        { "type": "textarea", "id": "answer", "label": "Answer", "default": "We offer free returns within 60 days of purchase on all full-price items." }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Page",
      "blocks": [
        { "type": "faq_item", "settings": { "question": "How long does shipping take?", "answer": "Standard shipping takes 5-7 business days. Express shipping (2-3 business days) is available at checkout. Free standard shipping on all orders over $150." } },
        { "type": "faq_item", "settings": { "question": "Can I change or cancel my order?", "answer": "Orders can be modified or cancelled within 1 hour of placement. After that, our fulfilment team will have already begun processing. Contact us as soon as possible and we'll do our best to help." } },
        { "type": "faq_item", "settings": { "question": "What is your return policy?", "answer": "We offer free returns within 60 days of purchase on all full-price items. Items must be unworn, unwashed, and in original packaging with tags attached. Sale items are final sale." } },
        { "type": "faq_item", "settings": { "question": "How do I find my size?", "answer": "Visit our size guide for detailed measurements. Our pieces are designed to be true to size. If you're between sizes, we recommend sizing up for a relaxed fit or sizing down for a compression feel." } },
        { "type": "faq_item", "settings": { "question": "How should I care for my Angles pieces?", "answer": "Machine wash cold on a gentle cycle. Do not tumble dry, lay flat or hang to dry. Do not iron or dry clean. Avoid fabric softeners as they can break down the performance fibres over time." } },
        { "type": "faq_item", "settings": { "question": "What fabrics do you use?", "answer": "We source premium performance textiles from elite mills across Europe and Japan. Our fabrics are four-way stretch, moisture-wicking, and squat-proof. Full fabric composition is listed on each product page." } }
      ]
    }
  ]
}
{% endschema %}
