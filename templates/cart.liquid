<div class="cart-page">
  <h1>Your <em>Cart</em></h1>

  {% if cart.item_count > 0 %}
    <div class="cart-grid">
      <div class="cart-items">
        {% for item in cart.items %}
          <div class="cart-item reveal">
            <img class="cart-item-img"
              src="{{ item.image | image_url: width: 200 }}"
              alt="{{ item.title }}">
            <div class="cart-item-details">
              <h3>{{ item.product.title }}</h3>
              <p>{{ item.variant.title }} · {{ item.price | money }}</p>
              <div class="cart-qty">
                <form action="{{ routes.cart_change_url }}" method="post">
                  <input type="hidden" name="id" value="{{ item.key }}">
                  <input type="hidden" name="quantity" value="{{ item.quantity | minus: 1 }}">
                  <button type="submit">−</button>
                </form>
                <span>{{ item.quantity }}</span>
                <form action="{{ routes.cart_change_url }}" method="post">
                  <input type="hidden" name="id" value="{{ item.key }}">
                  <input type="hidden" name="quantity" value="{{ item.quantity | plus: 1 }}">
                  <button type="submit">+</button>
                </form>
              </div>
            </div>
            <div>
              <p style="font-size:0.9rem; margin-bottom:1rem;">{{ item.line_price | money }}</p>
              <form action="{{ routes.cart_change_url }}" method="post">
                <input type="hidden" name="id" value="{{ item.key }}">
                <input type="hidden" name="quantity" value="0">
                <button type="submit" class="cart-item-remove">Remove</button>
              </form>
            </div>
          </div>
        {% endfor %}
      </div>

      <div class="cart-summary reveal reveal-delay-1">
        <h2>Order Summary</h2>
        <div class="cart-summary-row">
          <span>Subtotal</span>
          <span>{{ cart.total_price | money }}</span>
        </div>
        <div class="cart-summary-row">
          <span>Shipping</span>
          <span>Calculated at checkout</span>
        </div>
        <div class="cart-summary-row total">
          <span>Total</span>
          <span>{{ cart.total_price | money }}</span>
        </div>
        <a href="{{ routes.checkout }}" class="btn-primary">Checkout Securely</a>
        <p class="cart-note">Free shipping on orders over $150 · Free 60-day returns</p>
      </div>
    </div>

  {% else %}
    <div class="cart-empty reveal">
      <p>Your cart is empty.</p>
      <a href="{{ routes.collections_url }}" class="btn-primary">Explore Collection</a>
    </div>
  {% endif %}
</div>
