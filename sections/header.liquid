<header class="site-header" id="site-header">
  <a href="{{ routes.root_url }}" class="nav-logo">{{ shop.name | upcase }}</a>

  <nav>
    <ul class="nav-links">
      {% for link in linklists.main-menu.links %}
        <li><a href="{{ link.url }}">{{ link.title }}</a></li>
      {% endfor %}
    </ul>
  </nav>

  <div class="nav-right">
    <a href="{{ routes.account_url }}" class="nav-icon">Account</a>
    <a href="{{ routes.cart_url }}" class="nav-cart">
      Cart ({{ cart.item_count }})
    </a>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}
