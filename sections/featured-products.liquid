<style>
.featured-products { padding: 6rem 4rem 10rem; }
.featured-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 4rem; }
.featured-header h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem, 3.5vw, 3.5rem); font-weight: 300; }
.featured-header h2 em { font-style: italic; color: var(--warm); }
.view-all { font-size: 0.65rem; letter-spacing: 0.2em; color: var(--muted); text-decoration: none; text-transform: uppercase; border-bottom: 1px solid rgba(122,117,112,0.4); padding-bottom: 2px; transition: color 0.3s, border-color 0.3s; }
.view-all:hover { color: var(--warm); border-color: var(--warm); }
.featured-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5px; }
.featured-grid .product-card { aspect-ratio: 3/4; }
.featured-grid .product-card:first-child { grid-row: span 2; aspect-ratio: auto; }
</style>

<section class="featured-products">
  <div class="featured-header reveal">
    <h2>{{ section.settings.heading }} <em>{{ section.settings.heading_em }}</em></h2>
    {% if section.settings.collection != blank %}
      <a href="{{ section.settings.collection.url }}" class="view-all">View All Pieces</a>
    {% else %}
      <a href="{{ routes.collections_url }}" class="view-all">View All Pieces</a>
    {% endif %}
  </div>
  <div class="featured-grid">
    {% if section.settings.collection != blank and section.settings.collection.products_count > 0 %}
      {% for product in section.settings.collection.products limit: 5 %}
        <a href="{{ product.url }}" class="product-card reveal reveal-delay-{{ forloop.index0 }}">
          {% if product.featured_image %}
            <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title }}" loading="lazy">
          {% else %}
            <img src="https://images.unsplash.com/photo-1518611012118-696072aa579a?w=800&q=80&auto=format&fit=crop" alt="{{ product.title }}" loading="lazy">
          {% endif %}
          <div class="product-info">
            <p class="product-cat">{{ product.type }}</p>
            <p class="product-name">{{ product.title }}</p>
            <p class="product-price">{{ product.price | money }}</p>
          </div>
          <span class="product-add">+</span>
        </a>
      {% endfor %}
    {% else %}
      <div style="grid-column: span 3; text-align: center; padding: 6rem 0;">
        <p style="font-family:'Cormorant Garamond',serif; font-size:1.5rem; font-style:italic; color:var(--muted);">Select a collection in the theme customizer to display products here.</p>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Signature" },
    { "type": "text", "id": "heading_em", "label": "Heading Italic Word", "default": "Edit" },
    { "type": "collection", "id": "collection", "label": "Collection to Feature" }
  ],
  "presets": [{ "name": "Featured Products" }]
}
{% endschema %}
