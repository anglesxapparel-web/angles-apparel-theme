<style>
.collection-page { padding: 10rem 4rem 6rem; }
.collection-header { margin-bottom: 4rem; }
.collection-header h1 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.5rem,5vw,5rem); font-weight: 300; }
.collection-header h1 em { font-style: italic; color: var(--warm); }
.collection-header p { font-size: 0.82rem; color: var(--muted); line-height: 1.9; max-width: 500px; margin-top: 1rem; }
.collection-toolbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.06); }
.collection-count { font-size: 0.7rem; color: var(--muted); letter-spacing: 0.1em; }
.collection-sort select { background: none; border: 1px solid rgba(255,255,255,0.06); color: var(--muted); font-family: 'Jost', sans-serif; font-size: 0.7rem; padding: 0.6rem 1rem; cursor: pointer; outline: none; }
.collection-sort select option { background: var(--ink); }
.products-grid-collection { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5px; }
.products-grid-collection .product-card { aspect-ratio: 3/4; }
.collection-empty { text-align: center; padding: 6rem 0; grid-column: span 3; }
.collection-empty p { font-family: 'Cormorant Garamond', serif; font-size: 2rem; font-weight: 300; font-style: italic; color: var(--muted); margin-bottom: 2rem; }
</style>

<div class="collection-page">
  <div class="collection-header">
    <span class="section-label reveal">{{ collection.title }}</span>
    <h1 class="reveal"><em>{{ collection.title }}</em></h1>
    {% if collection.description != blank %}
      <p class="reveal reveal-delay-1">{{ collection.description }}</p>
    {% endif %}
  </div>

  <div class="collection-toolbar reveal">
    <span class="collection-count">{{ collection.products_count }} {% if collection.products_count == 1 %}piece{% else %}pieces{% endif %}</span>
    <div class="collection-sort">
      <select id="sort-by" name="sort_by">
        <option value="manual" {% if collection.sort_by == 'manual' %}selected{% endif %}>Featured</option>
        <option value="price-ascending" {% if collection.sort_by == 'price-ascending' %}selected{% endif %}>Price: Low to High</option>
        <option value="price-descending" {% if collection.sort_by == 'price-descending' %}selected{% endif %}>Price: High to Low</option>
        <option value="created-descending" {% if collection.sort_by == 'created-descending' %}selected{% endif %}>Newest</option>
        <option value="best-selling" {% if collection.sort_by == 'best-selling' %}selected{% endif %}>Best Selling</option>
      </select>
    </div>
  </div>

  <div class="products-grid-collection">
    {% for product in collection.products %}
      <a href="{{ product.url }}" class="product-card reveal reveal-delay-{{ forloop.index0 | modulo: 3 }}">
        {% if product.featured_image %}
          <img src="{{ product.featured_image | image_url: width: 1500 }}" alt="{{ product.title }}" loading="lazy">
        {% else %}
          <img src="https://images.unsplash.com/photo-1518611012118-696072aa579a?w=800&q=80&auto=format&fit=crop" alt="{{ product.title }}" loading="lazy">
        {% endif %}
        <div class="product-info">
          <p class="product-cat">{{ product.type }}</p>
          <p class="product-name">{{ product.title }}</p>
          <p class="product-price">{{ product.price | money }}</p>
        </div>
        <span class="product-add">+</span>
      </a>
    {% else %}
      <div class="collection-empty">
        <p>No products found.</p>
        <a href="{{ routes.collections_url }}" class="btn-primary">Browse All</a>
      </div>
    {% endfor %}
  </div>

  {% paginate collection.products by 12 %}
    {% if paginate.pages > 1 %}
      <div style="display:flex; justify-content:center; gap:1rem; margin-top:4rem;">
        {% if paginate.previous %}
          <a href="{{ paginate.previous.url }}" class="btn-outline">← Previous</a>
        {% endif %}
        {% if paginate.next %}
          <a href="{{ paginate.next.url }}" class="btn-outline">Next →</a>
        {% endif %}
      </div>
    {% endif %}
  {% endpaginate %}
</div>

<script>
  document.getElementById('sort-by')?.addEventListener('change', function() {
    const url = new URL(window.location.href);
    url.searchParams.set('sort_by', this.value);
    window.location.href = url.toString();
  });
</script>

{% schema %}
{
  "name": "Main Collection",
  "settings": [],
  "presets": [{ "name": "Main Collection" }]
}
{% endschema %}
