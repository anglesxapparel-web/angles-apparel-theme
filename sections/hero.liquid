<style>
.hero {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
  position: relative;
  overflow: hidden;
}
.hero-left {
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 8rem 4rem 6rem;
  position: relative;
  z-index: 2;
}
.hero-tag {
  font-family: 'Jost', sans-serif;
  font-size: 0.65rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--warm);
  margin-bottom: 2rem;
  opacity: 0;
  animation: fadeUp 1s ease 0.3s forwards;
}
.hero-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(4rem, 7vw, 7rem);
  font-weight: 300;
  line-height: 0.9;
  letter-spacing: -0.02em;
  margin-bottom: 2.5rem;
  opacity: 0;
  animation: fadeUp 1s ease 0.5s forwards;
}
.hero-title em { font-style: italic; color: var(--warm); }
.hero-sub {
  font-size: 0.8rem;
  font-weight: 200;
  letter-spacing: 0.12em;
  color: var(--muted);
  max-width: 320px;
  line-height: 1.9;
  margin-bottom: 3.5rem;
  opacity: 0;
  animation: fadeUp 1s ease 0.7s forwards;
}
.hero-btns {
  display: flex;
  gap: 1.5rem;
  align-items: center;
  opacity: 0;
  animation: fadeUp 1s ease 0.9s forwards;
}
.hero-right {
  position: relative;
  overflow: hidden;
}
.hero-img-wrap {
  position: absolute;
  inset: 0;
  opacity: 0;
  animation: fadeIn 1.4s ease 0.4s forwards;
}
.hero-img-wrap::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(to right, var(--ink) 0%, transparent 30%), linear-gradient(to top, var(--ink) 0%, transparent 25%);
}
.hero-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  filter: brightness(0.75) contrast(1.05);
}
.grid-overlay {
  position: absolute;
  inset: 0;
  background-image: linear-gradient(rgba(200,169,110,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(200,169,110,0.03) 1px, transparent 1px);
  background-size: 60px 60px;
  z-index: 1;
}
.hero-accent {
  position: absolute;
  bottom: 8%;
  left: 4rem;
  display: flex;
  align-items: center;
  gap: 1rem;
  opacity: 0;
  animation: fadeUp 1s ease 1.1s forwards;
}
.hero-accent span { font-size: 0.6rem; letter-spacing: 0.2em; color: var(--muted); }
.hero-accent::before { content: ''; width: 40px; height: 1px; background: var(--warm); }
.scroll-ind {
  position: absolute;
  right: 4rem;
  bottom: 6%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  opacity: 0;
  animation: fadeIn 1s ease 1.3s forwards;
  z-index: 10;
}
.scroll-ind span { font-size: 0.55rem; letter-spacing: 0.25em; color: var(--muted); writing-mode: vertical-lr; text-transform: uppercase; }
.scroll-line { width: 1px; height: 50px; background: linear-gradient(to bottom, var(--warm), transparent); animation: scrollPulse 2s ease infinite; }
</style>

<section class="hero">
  <div class="hero-left">
    <p class="hero-tag">{{ section.settings.tag }}</p>
    <h1 class="hero-title">
      {{ section.settings.title_line1 }}<br>
      <em>{{ section.settings.title_line2 }}</em><br>
      {{ section.settings.title_line3 }}
    </h1>
    <p class="hero-sub">{{ section.settings.subtitle }}</p>
    <div class="hero-btns">
      <a href="{{ section.settings.cta_url }}" class="btn-primary">{{ section.settings.cta_text }}</a>
      <a href="{{ section.settings.secondary_url }}" class="btn-ghost">{{ section.settings.secondary_text }}</a>
    </div>
    <div class="hero-accent">
      <span>{{ section.settings.accent_text }}</span>
    </div>
  </div>
  <div class="hero-right">
    <div class="hero-img-wrap">
      {% if section.settings.hero_image %}
        <img src="{{ section.settings.hero_image | image_url: width: 1200 }}" alt="Hero">
      {% else %}
        <img src="https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=1200&q=85&auto=format&fit=crop" alt="Hero">
      {% endif %}
      <div class="grid-overlay"></div>
    </div>
  </div>
  <div class="scroll-ind">
    <div class="scroll-line"></div>
    <span>Scroll</span>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "tag", "label": "Tag Line", "default": "SS 2026 Collection" },
    { "type": "text", "id": "title_line1", "label": "Title Line 1", "default": "Precision" },
    { "type": "text", "id": "title_line2", "label": "Title Line 2 (italic/gold)", "default": "in every" },
    { "type": "text", "id": "title_line3", "label": "Title Line 3", "default": "angle." },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Engineered for those who move with intention. Where performance architecture meets editorial craft." },
    { "type": "text", "id": "cta_text", "label": "Primary CTA Text", "default": "Explore Collection" },
    { "type": "url", "id": "cta_url", "label": "Primary CTA URL" },
    { "type": "text", "id": "secondary_text", "label": "Secondary CTA Text", "default": "Our Story" },
    { "type": "url", "id": "secondary_url", "label": "Secondary CTA URL" },
    { "type": "text", "id": "accent_text", "label": "Accent Text", "default": "Premium Athletic Lifestyle" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero Image" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
