<style>
.contact-page { padding: 10rem 4rem 8rem; }
.contact-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 8rem; align-items: start; }
.contact-info h1 { font-family: 'Cormorant Garamond', serif; font-size: clamp(3rem, 5vw, 5rem); font-weight: 300; line-height: 1; margin-bottom: 1.5rem; }
.contact-info h1 em { font-style: italic; color: var(--warm); }
.contact-info p { font-size: 0.82rem; color: var(--muted); line-height: 1.9; max-width: 400px; margin-bottom: 3rem; }
.contact-details { display: flex; flex-direction: column; gap: 2rem; }
.contact-detail-item { display: flex; flex-direction: column; gap: 0.4rem; }
.contact-detail-label { font-family: 'Syncopate', sans-serif; font-size: 0.5rem; letter-spacing: 0.3em; color: var(--warm); text-transform: uppercase; }
.contact-detail-value { font-size: 0.85rem; color: var(--paper); line-height: 1.7; }
.contact-divider { width: 40px; height: 1px; background: var(--warm); margin: 1rem 0; }
.contact-form-wrap { background: #0d0c0a; padding: 3.5rem; border: 1px solid rgba(255,255,255,0.05); }
.contact-form-wrap h2 { font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; font-weight: 300; margin-bottom: 2rem; }
.form-group { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.5rem; }
.form-group label { font-family: 'Syncopate', sans-serif; font-size: 0.5rem; letter-spacing: 0.25em; color: var(--muted); text-transform: uppercase; }
.form-group input, .form-group textarea, .form-group select { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); color: var(--paper); font-family: 'Jost', sans-serif; font-size: 0.82rem; padding: 0.9rem 1.2rem; outline: none; transition: border-color 0.3s; width: 100%; }
.form-group input::placeholder, .form-group textarea::placeholder { color: var(--muted); }
.form-group input:focus, .form-group textarea:focus, .form-group select:focus { border-color: rgba(200,169,110,0.4); }
.form-group textarea { resize: vertical; min-height: 140px; }
.form-group select { cursor: pointer; }
.form-group select option { background: var(--ink); }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.contact-form-wrap .btn-primary { width: 100%; text-align: center; margin-top: 0.5rem; display: block; cursor: pointer; }
</style>

<div class="contact-page">
  <div class="contact-layout">
    <div class="contact-info reveal">
      <span class="section-label">{{ section.settings.label }}</span>
      <h1>{{ section.settings.heading }} <em>{{ section.settings.heading_em }}</em></h1>
      <p>{{ section.settings.subheading }}</p>
      <div class="contact-divider"></div>
      <div class="contact-details">
        <div class="contact-detail-item">
          <span class="contact-detail-label">Email</span>
          <span class="contact-detail-value">{{ section.settings.email }}</span>
        </div>
        <div class="contact-detail-item">
          <span class="contact-detail-label">Hours</span>
          <span class="contact-detail-value">{{ section.settings.hours }}</span>
        </div>
        <div class="contact-detail-item">
          <span class="contact-detail-label">Location</span>
          <span class="contact-detail-value">{{ section.settings.location }}</span>
        </div>
        <div class="contact-detail-item">
          <span class="contact-detail-label">Response Time</span>
          <span class="contact-detail-value">{{ section.settings.response_time }}</span>
        </div>
      </div>
    </div>
    <div class="contact-form-wrap reveal reveal-delay-1">
      <h2>Send us a message</h2>
      {% form 'contact' %}
        {% if form.posted_successfully? %}
          <p style="font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-style:italic;color:var(--warm);padding:2rem 0;">Thank you — we'll be in touch shortly.</p>
        {% else %}
          <div class="form-row">
            <div class="form-group">
              <label>Name</label>
              <input type="text" name="contact[name]" placeholder="Your name" required>
            </div>
            <div class="form-group">
              <label>Email</label>
              <input type="email" name="contact[email]" placeholder="your@email.com" required>
            </div>
          </div>
          <div class="form-group">
            <label>Subject</label>
            <select name="contact[subject]">
              <option value="">Select a topic</option>
              <option>Order Enquiry</option>
              <option>Returns & Exchanges</option>
              <option>Sizing Help</option>
              <option>Wholesale</option>
              <option>Press & Collaborations</option>
              <option>Other</option>
            </select>
          </div>
          <div class="form-group">
            <label>Message</label>
            <textarea name="contact[body]" placeholder="How can we help?" required></textarea>
          </div>
          <button type="submit" class="btn-primary">Send Message</button>
        {% endif %}
      {% endform %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Contact Page",
  "settings": [
    { "type": "text", "id": "label", "label": "Section Label", "default": "Get In Touch" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Contact" },
    { "type": "text", "id": "heading_em", "label": "Heading Italic Word", "default": "Us" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Have a question about sizing, an order, or a collaboration? We'd love to hear from you." },
    { "type": "text", "id": "email", "label": "Email", "default": "hello@anglesapparel.com" },
    { "type": "text", "id": "hours", "label": "Hours", "default": "Monday – Friday, 9am – 6pm PST" },
    { "type": "text", "id": "location", "label": "Location", "default": "Los Angeles, California" },
    { "type": "text", "id": "response_time", "label": "Response Time", "default": "Within 1 business day" }
  ],
  "presets": [{ "name": "Contact Page" }]
}
{% endschema %}
