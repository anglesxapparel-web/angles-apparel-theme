<style>
.editorial-section { display: grid; grid-template-columns: 1fr 1fr; }
.editorial-visual { position: relative; overflow: hidden; min-height: 600px; }
.editorial-visual img { width: 100%; height: 100%; object-fit: cover; filter: brightness(0.7) contrast(1.05); display: block; }
.e-text-overlay { position: absolute; bottom: 2rem; left: 2rem; font-family: 'Cormorant Garamond', serif; font-size: 5rem; font-weight: 300; color: rgba(200,169,110,0.06); line-height: 1; pointer-events: none; font-style: italic; }
.editorial-content { background: #0d0c0a; padding: 5rem; display: flex; flex-direction: column; justify-content: center; }
.editorial-content h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem, 3vw, 3.2rem); font-weight: 300; line-height: 1.2; margin-bottom: 1.5rem; }
.editorial-content h2 em { font-style: italic; color: var(--warm); }
.editorial-content p { font-size: 0.82rem; line-height: 2; color: var(--muted); margin-bottom: 3rem; }
.angle-divider { width: 100%; height: 1px; background: linear-gradient(90deg, var(--warm), transparent); margin-bottom: 3rem; }
</style>

<section class="editorial-section">
  <div class="editorial-visual">
    {% if section.settings.image %}
      <img src="{{ section.settings.image | image_url: width: 1000 }}" alt="{{ section.settings.heading }}">
    {% else %}
      <img src="https://images.unsplash.com/photo-1483721310020-03333e577078?w=1000&q=85&auto=format&fit=crop" alt="Studio Collection">
    {% endif %}
    <div class="e-text-overlay">{{ section.settings.overlay_word }}</div>
  </div>
  <div class="editorial-content">
    <span class="section-label reveal">{{ section.settings.label }}</span>
    <h2 class="reveal">{{ section.settings.heading | newline_to_br }}</h2>
    <div class="angle-divider reveal"></div>
    <p class="reveal reveal-delay-1">{{ section.settings.body }}</p>
    <a href="{{ section.settings.cta_url }}" class="btn-primary reveal reveal-delay-2" style="width:fit-content;">{{ section.settings.cta_text }}</a>
  </div>
</section>

{% schema %}
{
  "name": "Editorial Feature",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Feature Image" },
    { "type": "text", "id": "overlay_word", "label": "Overlay Word", "default": "Studio" },
    { "type": "text", "id": "label", "label": "Section Label", "default": "The Studio Collection" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "Crafted for the\nspace between\nintensity & elegance." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Studio is our most versatile line — a seamless transition from movement to moment. Designed for those who take their mornings seriously and their evenings in stride." },
    { "type": "text", "id": "cta_text", "label": "CTA Text", "default": "Discover Studio" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" }
  ],
  "presets": [{ "name": "Editorial Feature" }]
}
{% endschema %}
